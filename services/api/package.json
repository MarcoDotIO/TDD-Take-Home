{
  "name": "@cola/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "bundle:lambda": "bun build src/lambda.ts --target=node --format=esm --outfile=dist/lambda/index.mjs",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/aws-sdk": "^0.3.0",
    "@aws-sdk/client-bedrock-runtime": "^3.940.0",
    "@aws-sdk/client-dynamodb": "^3.940.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/client-ses": "^3.940.0",
    "@aws-sdk/lib-dynamodb": "^3.940.0",
    "@cola/shared": "workspace:*"
  }
}
