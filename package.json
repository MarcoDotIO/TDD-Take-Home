{
  "name": "cola-label-verification",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infra"
  ],
  "scripts": {
    "build": "bun run --filter './packages/shared' build && bun run --filter './services/api' build && bun run --filter './apps/web' build && bun run --filter './infra' build",
    "dev:api": "bun --filter @cola/api dev",
    "dev:web": "bun --filter @cola/web dev",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "deploy:aws-web-domain": "node scripts/deploy-aws-web-domain.mjs",
    "verify:live-any-anthropic": "node scripts/verify-live-any-anthropic-e2e.mjs",
    "check:live-anthropic-readiness": "node scripts/check-live-anthropic-readiness.mjs",
    "check:live-anthropic-readiness:fast": "node scripts/check-live-anthropic-readiness.mjs --fast",
    "verify:live-anthropic": "node scripts/verify-live-anthropic-e2e.mjs",
    "verify:live-anthropic-api": "node scripts/verify-live-anthropic-api-e2e.mjs",
    "verify:live-bedrock-anthropic": "node scripts/verify-live-bedrock-anthropic-e2e.mjs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
